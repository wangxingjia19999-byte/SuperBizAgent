# 应用配置
APP_NAME=EnterpriseRAG
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=INFO

# FastAPI
API_V1_STR=/api/v1

# 向量化配置
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DB_TYPE=chroma

# LLM 配置
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# OpenAI API (可选)
# OPENAI_API_KEY=your-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_ORG_ID=your-org-id

# 文本切分参数
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# 检索参数
RETRIEVER_TOP_K=3
RERANKER_TOP_K=3
SIMILARITY_THRESHOLD=0.3

# 数据库
DATABASE_URL=sqlite:///./enterprise_rag.db

# Redis (可选)
# REDIS_URL=redis://localhost:6379/0
